{
  "name": "text-shot",
  "productName": "Text Shot",
  "version": "3.0.2",
  "description": "Fast macOS background OCR utility",
  "author": "Prem Sathisha Etagi",
  "license": "MIT",
  "scripts": {
    "clean": "bash scripts/clean-generated.sh",
    "build": "bash scripts/build-settings-app.sh",
    "start": "open \"./.generated/app/Text Shot.app\"",
    "dev": "npm run build && npm run start",
    "test": "bash scripts/test-native.sh",
    "typecheck": "bash scripts/typecheck-native.sh",
    "release:native": "bash scripts/release-native.sh",
    "release:native:minor": "bash scripts/release-native.sh --bump-minor",
    "dist": "bash scripts/release-native.sh"
  }
}
